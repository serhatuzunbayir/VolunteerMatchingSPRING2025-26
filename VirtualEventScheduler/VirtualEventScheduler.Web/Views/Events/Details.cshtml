@model VirtualEventScheduler.Web.Models.EventViewModel
@{ ViewData["Title"] = Model.Title; }

<div class="row">
    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <hr />
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Event Details</h5>
                <p class="card-text">@Model.Description</p>
                <dl class="row">
                    <dt class="col-sm-3">Date & Time</dt>
                    <dd class="col-sm-9">@Model.DateTime.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")</dd>
                    <dt class="col-sm-3">Location</dt>
                    <dd class="col-sm-9">@Model.Location</dd>
                    <dt class="col-sm-3">Capacity</dt>
                    <dd class="col-sm-9">@Model.RegisteredCount / @Model.Capacity participants</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-@(Model.Status == "Active" ? "success" : "secondary")">@Model.Status</span>
                        @if (Model.IsFull) { <span class="badge bg-warning">Full</span> }
                    </dd>
                </dl>
            </div>
        </div>

        @if (Context.Session.GetString("Token") != null)
        {
            @if (!Model.IsFull && Model.Status == "Active")
            {
                <form asp-action="Register" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-lg">Register for this Event</button>
                </form>
            }
            else if (Model.IsFull)
            {
                <div class="alert alert-warning">This event is full. Registration is closed.</div>
            }
            else
            {
                <div class="alert alert-info">Registration is not available for this event.</div>
            }
        }
        else
        {
            <div class="alert alert-info">
                Please <a asp-controller="Account" asp-action="Login">login</a> to register for this event.
            </div>
        }

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">Back to Events</a>
        </div>
    </div>
</div>
