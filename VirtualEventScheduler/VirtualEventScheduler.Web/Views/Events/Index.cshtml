@model List<VirtualEventScheduler.Web.Models.EventViewModel>
@{ ViewData["Title"] = "Events"; }

@{
    var role = Context.Session.GetString("UserRole");
    var canCreate = role == "Admin" || role == "Staff";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="mb-0">Upcoming Events</h2>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-success">+ Create Event</a>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Filter Events</h5>
        <form asp-action="Index" method="get">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-control">
                        <option value="">All</option>
                        <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
                        <option value="Completed" selected="@(ViewBag.Status == "Completed")">Completed</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Filter</button>
                    <a asp-action="Index" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No events found. Try adjusting your filters.</div>
}
else
{
    <div class="row">
        @foreach (var evt in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@evt.Title</h5>
                        <p class="card-text">@evt.Description</p>
                        <ul class="list-unstyled">
                            <li><strong>📅 Date:</strong> @evt.DateTime.ToString("dddd, MMMM dd, yyyy")</li>
                            <li><strong>🕒 Time:</strong> @evt.DateTime.ToString("hh:mm tt")</li>
                            <li><strong>📍 Location:</strong> @evt.Location</li>
                            <li><strong>👥 Capacity:</strong> @evt.RegisteredCount / @evt.Capacity</li>
                            <li>
                                <strong>Status:</strong>
                                <span class="badge bg-@(evt.Status == "Active" ? "success" : "secondary")">@evt.Status</span>
                                @if (evt.IsFull) { <span class="badge bg-warning">Full</span> }
                            </li>
                        </ul>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@evt.Id" class="btn btn-primary btn-sm">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
